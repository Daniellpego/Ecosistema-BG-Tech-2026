{
  "name": "painel-crm",
  "buildCommand": "mkdir -p out && cp -r painel-cfo/* out/",
  "installCommand": "",
  "outputDirectory": "out",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://crm-bgtech-backend.vercel.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Build-Version",
          "value": "2026-03-05-painel-cfo-api-proxy"
        }
      ]
    }
  ]
}
