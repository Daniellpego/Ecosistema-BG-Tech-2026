{
  "name": "painel-crm",
  "buildCommand": "cd painel-crm/apps/frontend && npm ci && npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "painel-crm/apps/frontend/.next",
  "framework": "nextjs",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://crm-bgtech-backend.vercel.app/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Build-Version",
          "value": "2026-03-05-painel-crm-nextjs"
        }
      ]
    }
  ]
}
