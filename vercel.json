{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": "site-principal",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Build-Version",
          "value": "2026-03-03-v2"
        }
      ]
    }
  ]
}
