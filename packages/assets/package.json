{
  "name": "@gradios/assets",
  "version": "1.0.0",
  "description": "Assets compartilhados (logos, favicons) com script de sincronização para o public/ de cada app.",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./logos/*": "./logos/*",
    "./favicons/*": "./favicons/*"
  },
  "files": [
    "logos",
    "favicons",
    "src",
    "scripts"
  ],
  "scripts": {
    "sync": "node scripts/sync.mjs",
    "build:webp": "node scripts/build-webp.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.0"
  }
}
