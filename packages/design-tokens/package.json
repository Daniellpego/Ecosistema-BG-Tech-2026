{
  "name": "@gradios/design-tokens",
  "version": "0.1.0",
  "description": "Single source of truth da identidade visual v2 (Apple-style light) — tokens, CSS vars e Tailwind preset.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens.ts",
      "default": "./src/tokens.ts"
    },
    "./css-vars": {
      "types": "./src/css-vars.ts",
      "default": "./src/css-vars.ts"
    },
    "./preset": {
      "types": "./src/preset.ts",
      "default": "./src/preset.ts"
    }
  },
  "files": [
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "dependencies": {
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
